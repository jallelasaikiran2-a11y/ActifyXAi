{
  "manifest_version": 3,
  "name": "ActifyXAI",
  "version": "8.0",
  "description": "Context-aware AI orchestration. Select text anywhere to execute intelligent actions.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["*://chatgpt.com/*", "*://*.chatgpt.com/*", "*://chat.openai.com/*"],
      "js": ["chatgpt_inject.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.perplexity.ai/*", "*://perplexity.ai/*"],
      "js": ["perplexity_inject.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://claude.ai/*"],
      "js": ["claude_inject.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://gemini.google.com/*"],
      "js": ["gemini_inject.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://chat.deepseek.com/*", "*://deepseek.com/*"],
      "js": ["deepseek_inject.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}